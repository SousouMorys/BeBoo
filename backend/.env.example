DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
OPENAI_API_KEY=""
PORT=3001
# Flagship demo configuration. Runtime defaults are gpt-5.6-terra, gpt-image-1-mini,
# low image quality, and gpt-4o-mini-tts when these optional values are omitted.
TEXT_MODEL=gpt-5.6-terra
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=high
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
